export default {
  async fetch(request, env) {
    // Handle CORS Preflight (OPTIONS)
    if (request.method === "OPTIONS") {
      return new Response(null, {
        headers: {
          "Access-Control-Allow-Origin": "*",
          "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
          "Access-Control-Allow-Headers": "Authorization, Content-Type",
        },
      });
    }

    const url = new URL(request.url);
    
    // Root URL check
    if (url.pathname === "/" || url.pathname === "") {
      return new Response("Nitheesh Cloud Downloader Proxy Active", {
        headers: { "Access-Control-Allow-Origin": "*" },
      });
    }

    // Strip out duplicate '/rest/1.0' prefix if the frontend passes it
    let cleanPath = url.pathname.replace(/^\/rest\/1\.0/, '');
    const targetUrl = `https://api.real-debrid.com/rest/1.0${cleanPath}${url.search}`;

    const modifiedHeaders = new Headers(request.headers);
    modifiedHeaders.set("Host", "api.real-debrid.com");

    const response = await fetch(targetUrl, {
      method: request.method,
      headers: modifiedHeaders,
      body: request.method !== "GET" && request.method !== "HEAD" ? await request.blob() : null,
    });

    const newHeaders = new Headers(response.headers);
    newHeaders.set("Access-Control-Allow-Origin", "*");

    return new Response(response.body, {
      status: response.status,
      statusText: response.statusText,
      headers: newHeaders,
    });
  },
};
